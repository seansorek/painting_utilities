# Copy this file to .env and fill in your values.

# Required: your Discord bot token.
DISCORD_TOKEN=your_bot_token_here

# Optional, DEVELOPMENT ONLY: register slash commands to a single guild for
# instant updates while testing. Leave BLANK for public/multi-server use so
# commands register globally (can take up to ~1 hour to propagate on first run).
DISCORD_GUILD_ID=

# Optional: per-user cooldown (seconds) on the expensive image commands.
# Defaults to 5 if unset.
COMMAND_COOLDOWN_SECONDS=5
